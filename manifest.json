{
  "description": "An extension to scrape the questions along with their respective answers on Ans to a PDF",
  "manifest_version": 3,
  "name": "Ans Scraper",
  "version": "1.3.2",
  "permissions": ["activeTab", "tabs"],
  "host_permissions": ["https://ans.app/*"],
  "optional_host_permissions": ["<all_urls>"],
  "content_scripts": [
    {
      "matches": ["https://ans.app/*"],
      "css": ["content/ans-page.css"],
      "js": ["content/ans-page.js"],
      "all_frames": true,
      "run_at": "document_idle"
    }
  ],

  "icons": {
    "48": "icon/icon-48.png",
    "96": "icon/icon-96.png"
  },

  "browser_specific_settings": {
    "gecko": {
      "id": "ansscraper@emiroven",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },
  "action": {
    "default_title": "Ans Scraper",
    "default_popup": "popup/scraper.html"
  }
}
